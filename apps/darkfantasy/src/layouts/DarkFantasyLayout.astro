---
import "@zoggy/ui/styles.css";
import "@zoggy/ui/dark-fantasy-theme.css";
import { gameName, studioName, gameStatus } from "@zoggy/branding";

const { title, description } = Astro.props;
const navItems = [
  { href: "/", label: "Home" },
  { href: "/about/", label: "About" },
  { href: "/monsters/", label: "Monsters" },
  { href: "/news/", label: "News" },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#090b0f" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;700;800;900&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="df-theme">
    <a class="skip-link" href="#main-content" style="--skip-bg: var(--df-gold); --skip-text: var(--df-abyss)">Skip to content</a>
    <div class="page-shell">
      <header class="df-header" aria-label={`${gameName} site header`}>
        <a class="df-brand" href="/" aria-label={`${gameName} home`}>
          <span class="df-mark" aria-hidden="true">DF</span>
          <span class="df-brand-name">{gameName}</span>
        </a>
        <nav class="df-nav" aria-label="Primary navigation">
          {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
      </header>
      <main id="main-content" class="main-content">
        <slot />
      </main>
      <footer class="df-footer">
        <span>{gameName}</span>
        <span>A {studioName} project &middot; {gameStatus}</span>
        <span class="df-footer-links">
          <a href="/privacy/">Privacy</a>
          <a href="/terms/">Terms</a>
        </span>
      </footer>
    </div>
  </body>
</html>

<style>
  .df-theme {
    --focus-color: var(--df-witchfire-bright);
    background: var(--df-abyss);
    color: var(--df-text);
    font-family: "Outfit", ui-sans-serif, system-ui, sans-serif;
    font-weight: 400;
    line-height: 1.6;
  }

  .df-theme::before {
    position: fixed;
    inset: 0;
    z-index: -1;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: 64px 64px;
    content: "";
    mask-image: linear-gradient(to bottom, black, transparent 70%);
    pointer-events: none;
  }

  .df-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem clamp(1rem, 4vw, 4rem);
    border-bottom: 1px solid var(--df-border);
    background: rgba(9, 11, 15, 0.88);
    backdrop-filter: blur(12px);
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .df-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-weight: 900;
    font-size: 1.05rem;
    letter-spacing: -0.02em;
    text-decoration: none;
    color: var(--df-text);
  }

  .df-mark {
    display: inline-flex;
    width: 2.2rem;
    height: 2.2rem;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    border: 1px solid var(--df-gold);
    background: linear-gradient(135deg, var(--df-blood-dark), var(--df-cosmic));
    color: var(--df-gold-bright);
    font-size: 0.85rem;
    font-weight: 900;
  }

  .df-nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.15rem;
  }

  .df-nav a {
    border-radius: 999px;
    padding: 0.4rem 0.65rem;
    font-size: 0.88rem;
    font-weight: 800;
    text-decoration: none;
    color: var(--df-text-secondary);
    transition: background 180ms ease, color 180ms ease;
  }

  .df-nav a:hover,
  .df-nav a:focus-visible {
    background: rgba(255, 255, 255, 0.06);
    color: var(--df-gold-bright);
  }

  .df-footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 1.25rem clamp(1rem, 4vw, 4rem);
    border-top: 1px solid var(--df-border);
    font-size: 0.85rem;
    color: var(--df-text-muted);
  }

  .df-footer a {
    color: var(--df-text-secondary);
    font-weight: 800;
    text-decoration: none;
  }

  .df-footer a:hover {
    color: var(--df-gold-bright);
  }

  .df-footer-links {
    display: inline-flex;
    gap: 0.8rem;
  }
</style>
