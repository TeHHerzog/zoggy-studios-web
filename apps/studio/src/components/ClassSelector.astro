---
import data from "../data/dark-fantasy-data.json";
const { classes, stats } = data;
---

<div class="class-selector-component">
  <!-- Class tabs selector -->
  <div class="class-tabs" role="tablist" aria-label="Dark Fantasy MMO Classes">
    {classes.map((cls, idx) => (
      <button 
        role="tab" 
        aria-selected={idx === 0 ? "true" : "false"} 
        aria-controls={`panel-${cls.code}`} 
        id={`tab-${cls.code}`} 
        class={`class-tab-btn ${idx === 0 ? "active" : ""}`}
        data-class-code={cls.code}
        data-class-data={JSON.stringify(cls)}
      >
        {cls.public_name}
      </button>
    ))}
  </div>

  <div class="class-display-card card">
    <!-- Screen reader live region -->
    <div id="class-sr-announcer" class="sr-only" aria-live="polite">
      Showing Royal class attributes and foundations.
    </div>

    <div class="class-detail-grid">
      <!-- Column 1: Lore and details -->
      <div class="class-lore-pane text-stack">
        <h2 id="active-class-name">{classes[0].public_name}</h2>
        <p class="eyebrow" style="color: var(--accent-color); font-weight: 800; font-size: 0.85rem; margin-top: -0.50rem;" id="active-class-presentation">
          Prince / Princess
        </p>
        <p id="active-class-role" class="class-role-desc">
          {classes[0].role}
        </p>
        
        <div class="derived-stats-box">
          <h4>Derived Class Metrics</h4>
          <div class="derived-grid">
            <div class="derived-item">
              <span class="d-label">HP Growth</span>
              <span class="d-val" id="growth-hp">{classes[0].hp_growth.min} - {classes[0].hp_growth.max} / lvl</span>
            </div>
            <div class="derived-item">
              <span class="d-label">MP Growth</span>
              <span class="d-val" id="growth-mp">{classes[0].mp_growth.min} - {classes[0].mp_growth.max} / lvl</span>
            </div>
            <div class="derived-item">
              <span class="d-label">Companion Cap</span>
              <span class="d-val" id="cap-companions">{classes[0].companion_cap} Active</span>
            </div>
            <div class="derived-item">
              <span class="d-label">Control Capacity</span>
              <span class="d-val" id="cap-control">+{classes[0].control_bonus} Bonus</span>
            </div>
          </div>
        </div>

        <div class="creation-summary-box">
          <div class="sum-row">
            <span>Foundation Total:</span>
            <span id="sum-foundation" class="bold">56</span>
          </div>
          <div class="sum-row">
            <span>Free Creation Points:</span>
            <span id="sum-free" class="bold" style="color: var(--accent-color);">{classes[0].free_points}</span>
          </div>
          <div class="sum-row border-top">
            <span>Total Starting Points:</span>
            <span class="bold">64</span>
          </div>
          <div class="points-note">
            * All free creation points must be allocated. Normal stat creation cap is 18 (Knight STR cap is 20).
          </div>
        </div>
      </div>

      <!-- Column 2: Character Image Gallery Panel -->
      <div class="class-image-pane">
        <div class="character-preview-box" title="Click to zoom full screen">
          <img 
            id="class-character-img" 
            src="/images/classes/royal_male_portrait.jpg" 
            alt="Royal Prince Portrait Render"
            class="character-img"
          />
        </div>
        
        <div class="preview-controls">
          <!-- Gender selection -->
          <div class="gender-selector">
            <button class="gender-btn active" data-gender="male" aria-label="Show Male Character Models">Male</button>
            <button class="gender-btn" data-gender="female" aria-label="Show Female Character Models">Female</button>
          </div>
          
          <!-- View selector thumbnails -->
          <div class="view-thumbnails" role="group" aria-label="Select Character View">
            <button class="thumb-btn active" data-view="portrait" aria-label="Switch to close-up portrait view">
              <img id="thumb-img-portrait" src="/images/classes/royal_male_portrait.jpg" alt="Portrait view thumbnail" />
              <span>Portrait</span>
            </button>
            <button class="thumb-btn" data-view="pose" aria-label="Switch to full-body pose view">
              <img id="thumb-img-pose" src="/images/classes/royal_male_pose.jpg" alt="Full body view thumbnail" />
              <span>Full Body</span>
            </button>
          </div>
        </div>
      </div>

      <!-- Column 3: Stats Panel -->
      <div class="class-stats-pane">
        <h3 class="pane-title">Class Foundation Attributes</h3>
        <div class="attribute-bars-list">
          {stats.map(st => (
            <div class="attribute-bar-group">
              <div class="bar-header">
                <span class="bar-name"><strong>{st.code}</strong> — {st.name}</span>
                <span class="bar-value" id={`val-${st.code}`}>{classes[0].foundation[st.code as keyof typeof classes[0].foundation]}</span>
              </div>
              <div class="bar-outer" role="progressbar" aria-valuemin="0" aria-valuemax="20" aria-valuenow={classes[0].foundation[st.code as keyof typeof classes[0].foundation]} id={`progress-${st.code}`} style={`--val-pct: ${(classes[0].foundation[st.code as keyof typeof classes[0].foundation] / 20) * 100}%`}>
                <div class="bar-inner" id={`inner-${st.code}`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Full screen Lightbox Modal -->
<div id="class-lightbox-modal" class="lightbox-modal" role="dialog" aria-modal="true" aria-label="Character Model Full Screen View" tabindex="-1">
  <button class="lightbox-close" aria-label="Close full screen view">&times;</button>
  <div class="lightbox-content">
    <img id="lightbox-img" src="" alt="" />
  </div>
</div>

<style>
  .class-selector-component {
    display: grid;
    gap: 1.5rem;
    width: 100%;
  }

  .class-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    border-bottom: 1px solid var(--card-border);
    padding-bottom: 0.75rem;
    justify-content: center;
  }

  .class-tab-btn {
    border-radius: 999px;
    border: 1px solid var(--card-border);
    background: var(--card-bg);
    color: var(--text-color);
    padding: 0.45rem 1.1rem;
    font-size: 0.88rem;
    font-weight: 800;
    cursor: pointer;
    transition: background 180ms ease, border-color 180ms ease, color 180ms ease, transform 180ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .class-tab-btn:hover {
    border-color: var(--card-hover-border);
    transform: scale(1.02);
  }

  .class-tab-btn.active {
    background: var(--accent-color);
    color: var(--skip-text);
    border-color: var(--accent-color);
  }

  .class-display-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-card);
    box-shadow: var(--card-shadow);
  }

  .class-detail-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    padding: clamp(1rem, 3vw, 2rem);
  }

  @media (min-width: 768px) {
    .class-detail-grid {
      grid-template-columns: 1.1fr 1fr;
    }
  }

  @media (min-width: 1200px) {
    .class-detail-grid {
      grid-template-columns: 1.1fr 1fr 1.1fr;
      gap: 2rem;
    }
  }

  .class-role-desc {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .pane-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 900;
    margin: 0 0 1.25rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .derived-stats-box {
    background: rgba(0, 0, 0, 0.02);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-sm);
    padding: 1rem;
    display: grid;
    gap: 0.75rem;
  }

  :global(.dark-theme) .derived-stats-box {
    background: rgba(255, 255, 255, 0.02);
  }

  .derived-stats-box h4 {
    margin: 0;
    font-size: 0.85rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent-color);
  }

  .derived-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .derived-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .d-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-weight: 700;
  }

  .d-val {
    font-size: 0.88rem;
    font-weight: 900;
    color: var(--text-secondary);
  }

  .creation-summary-box {
    background: rgba(0, 0, 0, 0.01);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-sm);
    padding: 1rem;
    display: grid;
    gap: 0.5rem;
  }

  .sum-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.88rem;
  }

  .sum-row.border-top {
    border-top: 1px solid var(--card-border);
    padding-top: 0.5rem;
    margin-top: 0.25rem;
  }

  .bold {
    font-weight: 900;
  }

  .points-note {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-style: italic;
    line-height: 1.35;
    margin-top: 0.25rem;
  }

  /* Character Image Gallery Pane */
  .class-image-pane {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .character-preview-box {
    position: relative;
    border-radius: var(--radius-card);
    border: 1px solid var(--card-border);
    overflow: hidden;
    background: rgba(0, 0, 0, 0.4);
    box-shadow: inset 0 0 30px rgba(0, 0, 0, 0.8);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 290px;
    height: 380px;
    cursor: zoom-in;
    transition: transform 180ms ease, border-color 180ms ease;
  }

  .character-preview-box:hover {
    border-color: var(--accent-color);
    transform: translateY(-2px);
  }

  .character-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: opacity 0.15s ease;
  }

  .preview-controls {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
    width: 100%;
    max-width: 290px;
  }

  .gender-selector {
    display: flex;
    gap: 0.35rem;
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid var(--card-border);
    padding: 0.2rem;
    border-radius: 999px;
    width: 100%;
  }

  :global(.dark-theme) .gender-selector {
    background: rgba(255, 255, 255, 0.02);
  }

  .gender-btn {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--text-secondary);
    font-size: 0.75rem;
    font-weight: 800;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    cursor: pointer;
    transition: background 180ms ease, color 180ms ease;
  }

  .gender-btn.active {
    background: var(--accent-color);
    color: var(--skip-text);
  }

  .view-thumbnails {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    width: 100%;
  }

  .thumb-btn {
    background: rgba(0, 0, 0, 0.1);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-sm);
    padding: 0.35rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    transition: border-color 180ms ease, transform 180ms ease, box-shadow 180ms ease;
  }

  :global(.dark-theme) .thumb-btn {
    background: rgba(255, 255, 255, 0.01);
  }

  .thumb-btn:hover {
    border-color: var(--card-hover-border);
    transform: translateY(-2px);
  }

  .thumb-btn.active {
    border-color: var(--accent-color);
    box-shadow: 0 0 8px rgba(245, 158, 11, 0.15);
  }

  .thumb-btn img {
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 4px;
    object-fit: cover;
    object-position: center top;
    background: #000;
    flex-shrink: 0;
  }

  .thumb-btn span {
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-color);
  }

  .attribute-bars-list {
    display: grid;
    gap: 1.15rem;
  }

  .bar-header {
    display: flex;
    justify-content: space-between;
    font-size: 0.88rem;
    margin-bottom: 0.35rem;
  }

  .bar-name {
    color: var(--text-secondary);
  }

  .bar-value {
    font-weight: 900;
    color: var(--accent-color);
  }

  .bar-outer {
    height: 0.65rem;
    background: rgba(0, 0, 0, 0.08);
    border-radius: 999px;
    overflow: hidden;
    position: relative;
  }

  :global(.dark-theme) .bar-outer {
    background: rgba(255, 255, 255, 0.08);
  }

  .bar-inner {
    height: 100%;
    border-radius: 999px;
    background: var(--accent-color);
    width: var(--val-pct);
    transition: width 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* Full Screen Lightbox Modal */
  .lightbox-modal {
    position: fixed;
    inset: 0;
    background: rgba(5, 5, 5, 0.94);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    opacity: 0;
    transition: opacity 0.2s ease;
    cursor: zoom-out;
    backdrop-filter: blur(8px);
    padding: 2rem;
  }

  .lightbox-modal.active {
    display: flex;
    opacity: 1;
  }

  .lightbox-content {
    position: relative;
    max-width: 90vw;
    max-height: 85vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-modal img {
    max-width: 100%;
    max-height: 85vh;
    object-fit: contain;
    border-radius: var(--radius-sm);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.7);
    transform: scale(0.96);
    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .lightbox-modal.active img {
    transform: scale(1);
  }

  .lightbox-close {
    position: absolute;
    top: 1.5rem;
    right: 2rem;
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #ffffff;
    font-size: 2rem;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10000;
    transition: background 150ms ease, color 150ms ease;
    line-height: 1;
  }

  .lightbox-close:hover {
    background: var(--accent-color);
    color: var(--skip-text);
  }

  /* Accessibility focus ring */
  .class-tab-btn:focus-visible, .gender-btn:focus-visible, .thumb-btn:focus-visible, .lightbox-close:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px var(--accent-color);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script>
  const tabButtons = document.querySelectorAll('.class-tab-btn');
  const genderButtons = document.querySelectorAll('.gender-btn');
  const thumbButtons = document.querySelectorAll('.thumb-btn');
  const announcer = document.getElementById('class-sr-announcer');

  const activeName = document.getElementById('active-class-name');
  const activePresentation = document.getElementById('active-class-presentation');
  const activeRole = document.getElementById('active-class-role');
  
  const growthHp = document.getElementById('growth-hp');
  const growthMp = document.getElementById('growth-mp');
  const capCompanions = document.getElementById('cap-companions');
  const capControl = document.getElementById('cap-control');
  
  const sumFoundation = document.getElementById('sum-foundation');
  const sumFree = document.getElementById('sum-free');
  
  const classImg = document.getElementById('class-character-img') as HTMLImageElement | null;
  const thumbImgPortrait = document.getElementById('thumb-img-portrait') as HTMLImageElement | null;
  const thumbImgPose = document.getElementById('thumb-img-pose') as HTMLImageElement | null;

  // Lightbox selectors
  const lightboxModal = document.getElementById('class-lightbox-modal');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
  const lightboxClose = document.querySelector('.lightbox-close');

  let activeClassCode = 'prince';
  let activeGender = 'male';
  let activeView = 'portrait';

  // Preload all 20 variations so swaps are instant and lag-free
  const classesList = ['royal', 'knight', 'elf', 'mage', 'priest'];
  const gendersList = ['male', 'female'];
  const viewsList = ['portrait', 'pose'];

  classesList.forEach(cls => {
    gendersList.forEach(gen => {
      viewsList.forEach(vw => {
        const img = new Image();
        img.src = `/images/classes/${cls}_${gen}_${vw}.jpg`;
      });
    });
  });

  function updateCharacterDisplay() {
    let classPrefix = activeClassCode;
    if (activeClassCode === 'prince') {
      classPrefix = 'royal';
    }

    // 1. Update thumbnail preview images instantly
    if (thumbImgPortrait) {
      thumbImgPortrait.src = `/images/classes/${classPrefix}_${activeGender}_portrait.jpg`;
      thumbImgPortrait.alt = `${activeClassCode} ${activeGender} portrait thumbnail`;
    }
    if (thumbImgPose) {
      thumbImgPose.src = `/images/classes/${classPrefix}_${activeGender}_pose.jpg`;
      thumbImgPose.alt = `${activeClassCode} ${activeGender} pose thumbnail`;
    }

    // 2. Update large preview image instantly (no setTimeout delay)
    if (classImg) {
      classImg.style.opacity = '0.3';
      
      // Update src immediately, because preloaded images swap on the same tick
      classImg.src = `/images/classes/${classPrefix}_${activeGender}_${activeView}.jpg`;
      classImg.alt = `${activeClassCode} ${activeGender} ${activeView} render`;
      
      // Hook into onload to fade back in once the browser paints it
      if (classImg.complete) {
        classImg.style.opacity = '1';
      } else {
        classImg.onload = () => {
          classImg.style.opacity = '1';
        };
      }
    }
  }

  // Handle class tabs click
  tabButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      // Remove active states
      tabButtons.forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
      });

      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');

      let data = { code: '', public_name: '', presentation_names: [], role: '', foundation: {}, free_points: 0, hp_growth: {}, mp_growth: {}, companion_cap: 0, control_bonus: 0 };
      try {
        data = JSON.parse(btn.getAttribute('data-class-data') || '{}');
      } catch (e) {
        console.error(e);
        return;
      }

      activeClassCode = data.code;

      // Update text
      if (activeName) activeName.textContent = data.public_name;
      if (activePresentation) {
        activePresentation.textContent = data.presentation_names.join(' / ');
      }
      if (activeRole) activeRole.textContent = data.role;

      // Update derived stats
      if (growthHp && data.hp_growth) growthHp.textContent = `${data.hp_growth.min} - ${data.hp_growth.max} / lvl`;
      if (growthMp && data.mp_growth) growthMp.textContent = `${data.mp_growth.min} - ${data.mp_growth.max} / lvl`;
      if (capCompanions) capCompanions.textContent = `${data.companion_cap} Active`;
      if (capControl) capControl.textContent = `+${data.control_bonus} Bonus`;

      // Update creation summaries
      let foundationSum = 0;
      Object.keys(data.foundation).forEach((k) => {
        const valNum = (data.foundation as any)[k] || 0;
        foundationSum += valNum;
        
        // Update bars
        const valElem = document.getElementById(`val-${k}`);
        const innerBar = document.getElementById(`inner-${k}`);
        const outerBar = document.getElementById(`progress-${k}`);

        if (valElem) valElem.textContent = valNum.toString();
        if (outerBar) {
          outerBar.setAttribute('aria-valuenow', valNum.toString());
          outerBar.style.setProperty('--val-pct', `${(valNum / 20) * 100}%`);
        }
        if (innerBar) {
          innerBar.style.width = `${(valNum / 20) * 100}%`;
        }
      });

      if (sumFoundation) sumFoundation.textContent = foundationSum.toString();
      if (sumFree) sumFree.textContent = data.free_points.toString();

      // Update character display
      updateCharacterDisplay();

      // Screen reader announcements
      if (announcer) {
        announcer.textContent = `Showing ${data.public_name} class attributes and foundations.`;
      }
    });
  });

  // Handle gender tabs click
  genderButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      genderButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      activeGender = btn.getAttribute('data-gender') || 'male';
      updateCharacterDisplay();
    });
  });

  // Handle view thumbnail clicks
  thumbButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      thumbButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      activeView = btn.getAttribute('data-view') || 'portrait';
      updateCharacterDisplay();
    });
  });

  // Open Lightbox on Main image click
  const previewBox = document.querySelector('.character-preview-box');
  if (previewBox && classImg && lightboxModal && lightboxImg) {
    previewBox.addEventListener('click', () => {
      lightboxImg.src = classImg.src;
      lightboxImg.alt = classImg.alt;
      lightboxModal.classList.add('active');
      lightboxModal.focus();
    });
  }

  // Close Lightbox function
  function closeLightbox() {
    if (lightboxModal) {
      lightboxModal.classList.remove('active');
    }
  }

  // Click on background or close button to exit full screen
  if (lightboxModal) {
    lightboxModal.addEventListener('click', () => {
      closeLightbox();
    });

    // Support Escape key to close
    lightboxModal.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Escape') {
        closeLightbox();
      }
    });
  }
</script>
