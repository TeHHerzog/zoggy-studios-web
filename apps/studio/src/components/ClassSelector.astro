---
import data from "../data/dark-fantasy-data.json";
const { classes, stats } = data;
---

<div class="class-selector-component">
  <!-- Class tabs selector -->
  <div class="class-tabs" role="tablist" aria-label="Dark Fantasy MMO Classes">
    {classes.map((cls, idx) => (
      <button 
        role="tab" 
        aria-selected={idx === 0 ? "true" : "false"} 
        aria-controls={`panel-${cls.code}`} 
        id={`tab-${cls.code}`} 
        class={`class-tab-btn ${idx === 0 ? "active" : ""}`}
        data-class-code={cls.code}
        data-class-data={JSON.stringify(cls)}
      >
        {cls.public_name}
      </button>
    ))}
  </div>

  <div class="class-display-card card">
    <!-- Screen reader live region -->
    <div id="class-sr-announcer" class="sr-only" aria-live="polite">
      Showing Royal class attributes and foundations.
    </div>

    <div class="class-detail-grid">
      <!-- Column 1: Lore and details -->
      <div class="class-lore-pane text-stack">
        <h2 id="active-class-name">{classes[0].public_name}</h2>
        <p class="eyebrow" style="color: var(--accent-color); font-weight: 800; font-size: 0.85rem; margin-top: -0.50rem;" id="active-class-presentation">
          Prince / Princess
        </p>
        <p id="active-class-role" class="class-role-desc">
          {classes[0].role}
        </p>
        
        <div class="derived-stats-box">
          <h4>Derived Class Metrics</h4>
          <div class="derived-grid">
            <div class="derived-item">
              <span class="d-label">HP Growth</span>
              <span class="d-val" id="growth-hp">{classes[0].hp_growth.min} - {classes[0].hp_growth.max} / lvl</span>
            </div>
            <div class="derived-item">
              <span class="d-label">MP Growth</span>
              <span class="d-val" id="growth-mp">{classes[0].mp_growth.min} - {classes[0].mp_growth.max} / lvl</span>
            </div>
            <div class="derived-item">
              <span class="d-label">Companion Cap</span>
              <span class="d-val" id="cap-companions">{classes[0].companion_cap} Active</span>
            </div>
            <div class="derived-item">
              <span class="d-label">Control Capacity</span>
              <span class="d-val" id="cap-control">+{classes[0].control_bonus} Bonus</span>
            </div>
          </div>
        </div>

        <div class="creation-summary-box">
          <div class="sum-row">
            <span>Foundation Total:</span>
            <span id="sum-foundation" class="bold">56</span>
          </div>
          <div class="sum-row">
            <span>Free Creation Points:</span>
            <span id="sum-free" class="bold" style="color: var(--accent-color);">{classes[0].free_points}</span>
          </div>
          <div class="sum-row border-top">
            <span>Total Starting Points:</span>
            <span class="bold">64</span>
          </div>
          <div class="points-note">
            * All free creation points must be allocated. Normal stat creation cap is 18 (Knight STR cap is 20).
          </div>
        </div>
      </div>

      <!-- Column 2: Character Image Panel -->
      <div class="class-image-pane">
        <div class="character-preview-box">
          <img 
            id="class-character-img" 
            src="/images/classes/royal_male_pose.jpg" 
            alt="Royal Prince Model Render"
            class="character-img"
          />
          <div class="gender-selector">
            <button class="gender-btn active" data-gender="male" aria-label="Show Male Character Model">Male</button>
            <button class="gender-btn" data-gender="female" aria-label="Show Female Character Model">Female</button>
          </div>
        </div>
      </div>

      <!-- Column 3: Stats Panel -->
      <div class="class-stats-pane">
        <h3 class="pane-title">Class Foundation Attributes</h3>
        <div class="attribute-bars-list">
          {stats.map(st => (
            <div class="attribute-bar-group">
              <div class="bar-header">
                <span class="bar-name"><strong>{st.code}</strong> — {st.name}</span>
                <span class="bar-value" id={`val-${st.code}`}>{classes[0].foundation[st.code as keyof typeof classes[0].foundation]}</span>
              </div>
              <div class="bar-outer" role="progressbar" aria-valuemin="0" aria-valuemax="20" aria-valuenow={classes[0].foundation[st.code as keyof typeof classes[0].foundation]} id={`progress-${st.code}`} style={`--val-pct: ${(classes[0].foundation[st.code as keyof typeof classes[0].foundation] / 20) * 100}%`}>
                <div class="bar-inner" id={`inner-${st.code}`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .class-selector-component {
    display: grid;
    gap: 1.5rem;
    width: 100%;
  }

  .class-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    border-bottom: 1px solid var(--card-border);
    padding-bottom: 0.75rem;
    justify-content: center;
  }

  .class-tab-btn {
    border-radius: 999px;
    border: 1px solid var(--card-border);
    background: var(--card-bg);
    color: var(--text-color);
    padding: 0.45rem 1.1rem;
    font-size: 0.88rem;
    font-weight: 800;
    cursor: pointer;
    transition: background 180ms ease, border-color 180ms ease, color 180ms ease, transform 180ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .class-tab-btn:hover {
    border-color: var(--card-hover-border);
    transform: scale(1.02);
  }

  .class-tab-btn.active {
    background: var(--accent-color);
    color: var(--skip-text);
    border-color: var(--accent-color);
  }

  .class-display-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-card);
    box-shadow: var(--card-shadow);
  }

  .class-detail-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    padding: clamp(1rem, 3vw, 2rem);
  }

  @media (min-width: 768px) {
    .class-detail-grid {
      grid-template-columns: 1.1fr 1fr;
    }
  }

  @media (min-width: 1200px) {
    .class-detail-grid {
      grid-template-columns: 1fr 1.1fr 1fr;
      gap: 2rem;
    }
  }

  .class-role-desc {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .pane-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 900;
    margin: 0 0 1.25rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .derived-stats-box {
    background: rgba(0, 0, 0, 0.02);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-sm);
    padding: 1rem;
    display: grid;
    gap: 0.75rem;
  }

  :global(.dark-theme) .derived-stats-box {
    background: rgba(255, 255, 255, 0.02);
  }

  .derived-stats-box h4 {
    margin: 0;
    font-size: 0.85rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent-color);
  }

  .derived-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .derived-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .d-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-weight: 700;
  }

  .d-val {
    font-size: 0.88rem;
    font-weight: 900;
    color: var(--text-secondary);
  }

  .creation-summary-box {
    background: rgba(0, 0, 0, 0.01);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-sm);
    padding: 1rem;
    display: grid;
    gap: 0.5rem;
  }

  .sum-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.88rem;
  }

  .sum-row.border-top {
    border-top: 1px solid var(--card-border);
    padding-top: 0.5rem;
    margin-top: 0.25rem;
  }

  .bold {
    font-weight: 900;
  }

  .points-note {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-style: italic;
    line-height: 1.35;
    margin-top: 0.25rem;
  }

  /* Character Image Pane */
  .class-image-pane {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .character-preview-box {
    position: relative;
    border-radius: var(--radius-card);
    border: 1px solid var(--card-border);
    overflow: hidden;
    background: rgba(0, 0, 0, 0.4);
    box-shadow: inset 0 0 40px rgba(0, 0, 0, 0.8);
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 320px;
    height: 420px;
  }

  .character-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: opacity 0.2s ease;
  }

  .gender-selector {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.5rem;
    background: rgba(0, 0, 0, 0.75);
    border: 1px solid rgba(255, 255, 255, 0.15);
    padding: 0.25rem;
    border-radius: 999px;
    z-index: 2;
    backdrop-filter: blur(10px);
  }

  .gender-btn {
    background: transparent;
    border: none;
    color: #a0a0a0;
    font-size: 0.75rem;
    font-weight: 800;
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    cursor: pointer;
    transition: background 180ms ease, color 180ms ease;
  }

  .gender-btn.active {
    background: var(--accent-color);
    color: var(--skip-text);
  }

  .attribute-bars-list {
    display: grid;
    gap: 1.15rem;
  }

  .bar-header {
    display: flex;
    justify-content: space-between;
    font-size: 0.88rem;
    margin-bottom: 0.35rem;
  }

  .bar-name {
    color: var(--text-secondary);
  }

  .bar-value {
    font-weight: 900;
    color: var(--accent-color);
  }

  .bar-outer {
    height: 0.65rem;
    background: rgba(0, 0, 0, 0.08);
    border-radius: 999px;
    overflow: hidden;
    position: relative;
  }

  :global(.dark-theme) .bar-outer {
    background: rgba(255, 255, 255, 0.08);
  }

  .bar-inner {
    height: 100%;
    border-radius: 999px;
    background: var(--accent-color);
    width: var(--val-pct);
    transition: width 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* Accessibility focus ring */
  .class-tab-btn:focus-visible, .gender-btn:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px var(--accent-color);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script>
  const tabButtons = document.querySelectorAll('.class-tab-btn');
  const genderButtons = document.querySelectorAll('.gender-btn');
  const announcer = document.getElementById('class-sr-announcer');

  const activeName = document.getElementById('active-class-name');
  const activePresentation = document.getElementById('active-class-presentation');
  const activeRole = document.getElementById('active-class-role');
  
  const growthHp = document.getElementById('growth-hp');
  const growthMp = document.getElementById('growth-mp');
  const capCompanions = document.getElementById('cap-companions');
  const capControl = document.getElementById('cap-control');
  
  const sumFoundation = document.getElementById('sum-foundation');
  const sumFree = document.getElementById('sum-free');
  const classImg = document.getElementById('class-character-img') as HTMLImageElement | null;

  let activeClassCode = 'prince';
  let activeGender = 'male';

  function updateCharacterImage() {
    if (classImg) {
      let classPrefix = activeClassCode;
      if (activeClassCode === 'prince') {
        classPrefix = 'royal';
      }
      classImg.style.opacity = '0.3';
      
      setTimeout(() => {
        classImg.src = `/images/classes/${classPrefix}_${activeGender}_pose.jpg`;
        classImg.alt = `${activeClassCode} ${activeGender} model render`;
        classImg.style.opacity = '1';
      }, 100);
    }
  }

  // Handle class tabs click
  tabButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      // Remove active states
      tabButtons.forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
      });

      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');

      let data = { code: '', public_name: '', presentation_names: [], role: '', foundation: {}, free_points: 0, hp_growth: {}, mp_growth: {}, companion_cap: 0, control_bonus: 0 };
      try {
        data = JSON.parse(btn.getAttribute('data-class-data') || '{}');
      } catch (e) {
        console.error(e);
        return;
      }

      activeClassCode = data.code;

      // Update text
      if (activeName) activeName.textContent = data.public_name;
      if (activePresentation) {
        activePresentation.textContent = data.presentation_names.join(' / ');
      }
      if (activeRole) activeRole.textContent = data.role;

      // Update derived stats
      if (growthHp && data.hp_growth) growthHp.textContent = `${data.hp_growth.min} - ${data.hp_growth.max} / lvl`;
      if (growthMp && data.mp_growth) growthMp.textContent = `${data.mp_growth.min} - ${data.mp_growth.max} / lvl`;
      if (capCompanions) capCompanions.textContent = `${data.companion_cap} Active`;
      if (capControl) capControl.textContent = `+${data.control_bonus} Bonus`;

      // Update creation summaries
      let foundationSum = 0;
      Object.keys(data.foundation).forEach((k) => {
        const valNum = (data.foundation as any)[k] || 0;
        foundationSum += valNum;
        
        // Update bars
        const valElem = document.getElementById(`val-${k}`);
        const innerBar = document.getElementById(`inner-${k}`);
        const outerBar = document.getElementById(`progress-${k}`);

        if (valElem) valElem.textContent = valNum.toString();
        if (outerBar) {
          outerBar.setAttribute('aria-valuenow', valNum.toString());
          outerBar.style.setProperty('--val-pct', `${(valNum / 20) * 100}%`);
        }
        if (innerBar) {
          innerBar.style.width = `${(valNum / 20) * 100}%`;
        }
      });

      if (sumFoundation) sumFoundation.textContent = foundationSum.toString();
      if (sumFree) sumFree.textContent = data.free_points.toString();

      // Update character illustration
      updateCharacterImage();

      // Screen reader announcements
      if (announcer) {
        announcer.textContent = `Showing ${data.public_name} class attributes and foundations.`;
      }
    });
  });

  // Handle gender tabs click
  genderButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      genderButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      activeGender = btn.getAttribute('data-gender') || 'male';
      updateCharacterImage();
    });
  });
</script>
