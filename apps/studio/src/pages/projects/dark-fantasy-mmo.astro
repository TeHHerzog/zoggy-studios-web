---
import { gameName, gameStatus, studioName } from "@zoggy/branding";
import StudioLayout from "../../layouts/StudioLayout.astro";

const title = `${gameName} | ${studioName}`;
const description = `${gameName} is an old-school-inspired dark fantasy MMORPG in ${gameStatus.toLowerCase()} development.`;
---

<StudioLayout title={title} description={description}>
  <section class="section" aria-labelledby="mmo-title">
    <div class="page-content text-stack">
      <p class="eyebrow">{gameStatus}</p>
      <h1 id="mmo-title" class="page-title">{gameName}</h1>
      <p class="page-intro">An old-school-inspired dark fantasy MMORPG focused on dangerous exploration, meaningful character development, deeply authored creatures, and a persistent server-controlled world.</p>
    </div>
  </section>

  <section class="section" aria-label="What is being built">
    <div class="section-inner wide-grid">
      <article class="card text-stack">
        <h2>What is being built</h2>
        <ul class="note-list">
          <li>Godot 4.7 game client with multiplayer architecture</li>
          <li>Authoritative Golang game server with WebSocket communication</li>
          <li>Character creation and progression with seven core stats</li>
          <li>Combat, abilities, casting, inventory, quests, and world systems</li>
          <li>Web-based administration and content management tools</li>
          <li>World-building and terrain authoring pipeline</li>
          <li>Structured content pipeline for monsters, items, quests, and lore</li>
        </ul>
      </article>
      <article class="card text-stack">
        <h2>Current development focus</h2>
        <ul class="note-list">
          <li>Server lifecycle and observability infrastructure</li>
          <li>Login and character flow implementation</li>
          <li>Character stat allocation and progression systems</li>
          <li>Content relationships and administration tooling</li>
          <li>First playable world slice</li>
          <li>Monster and item content integration</li>
        </ul>
      </article>
    </div>
  </section>

  <section class="section" aria-label="Game pillars">
    <div class="section-inner">
      <div class="section-heading">
        <h2>Public-safe game pillars</h2>
      </div>
      <div class="wide-grid">
        <article class="card">
          <h3>Old-school MMORPG progression</h3>
          <p>Leveling, stats, classes, and equipment that respect traditional role-playing depth while being accessible to modern players.</p>
        </article>
        <article class="card">
          <h3>Server-authoritative gameplay</h3>
          <p>The Go server owns all gameplay decisions. The client is a window into a persistent, trusted world state.</p>
        </article>
        <article class="card">
          <h3>Dangerous dark fantasy world</h3>
          <p>A ruined, mythic tone with cosmic and corrupted elements, balanced with readability and accessibility.</p>
        </article>
        <article class="card">
          <h3>Strong class identity</h3>
          <p>The Knight, Elf, Mage, and Prince establish distinct play styles with meaningful stat allocation and ability trees.</p>
        </article>
        <article class="card">
          <h3>Deep monster ecology</h3>
          <p>Hundreds of creatures with structured data connecting lore, combat, loot, AI, and world placement.</p>
        </article>
        <article class="card">
          <h3>Data-driven content</h3>
          <p>Monsters, items, zones, and quests are defined in structured data that feeds the server, client, and eventual wiki.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section" aria-label="Technical stack">
    <div class="section-inner">
      <div class="callout text-stack">
        <h2>Technical stack</h2>
        <p>Godot 4.7 client, Go WebSocket server, Protobuf messaging, persistent database storage, web administration layer, structured content pipelines, and AI-assisted solo development workflows.</p>
        <p class="supporting">Architecture and infrastructure details remain private during development.</p>
      </div>
    </div>
  </section>
</StudioLayout>

<style>
  .studio-theme .card h3 {
    margin-bottom: 0.5rem;
  }
</style>
