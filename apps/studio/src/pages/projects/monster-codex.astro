---
import { studioName } from "@zoggy/branding";
import StudioLayout from "../../layouts/StudioLayout.astro";

const title = `Monster Codex | ${studioName}`;
const description = `A structured creature-authoring system for the Dark Fantasy MMO connecting lore, combat, art, and game data.`;
---
<StudioLayout title={title} description={description}>
  <section class="codex-hero" aria-labelledby="codex-title">
    <div class="codex-hero-inner">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/projects/">Projects</a>
        <span aria-hidden="true">/</span>
        <span class="current">Monster Codex</span>
      </nav>
      <p class="eyebrow">Active development</p>
      <h1 id="codex-title">Monster Codex</h1>
      <p class="codex-lead">A structured creature-authoring system that connects monster identity, visual direction, lore, ecology, combat statistics, abilities, spawning, loot, and database records into one pipeline.</p>
    </div>
  </section>
  <section class="section" aria-label="Codex overview" style="position: relative">
    <div class="section-inner wide-grid">
      <article class="card text-stack">
        <h2>The scope</h2>
        <p>Hundreds of creatures spanning serious dark fantasy monsters, trick monsters, clockwork constructs, aberrations, bosses, mini-bosses, and unique individual records. Each creature carries structured data connecting every aspect of its existence in the game world.</p>
      </article>
      <article class="card text-stack">
        <h2>What the pipeline connects</h2>
        <ul class="note-list">
          <li>Visual direction and creature artwork</li>
          <li>Public lore and in-world ecology</li>
          <li>Combat statistics and abilities</li>
          <li>AI behavior and spawning rules</li>
          <li>Loot tables and quest integration</li>
          <li>Database records and in-game presentation</li>
        </ul>
      </article>
    </div>
  </section>
  <section class="section" aria-label="Case study" style="background: radial-gradient(circle at 18% 22%, rgba(192,132,252,0.15), transparent 24rem), radial-gradient(circle at 82% 78%, rgba(244,63,94,0.1), transparent 22rem)">
    <div class="section-inner">
      <div class="section-heading">
        <h2>Case study: Chonkroach</h2>
        <p>A single creature that demonstrates how the Codex works end to end, from concept to in-game data.</p>
      </div>
      <div class="wide-grid">
        <article class="card"><h3>Creature artwork</h3><p>Visual concept and in-game representation.</p></article>
        <article class="card"><h3>Public lore</h3><p>Short in-world description and ecological context.</p></article>
        <article class="card"><h3>Dimensions & family</h3><p>Height, weight, and creature family classification.</p></article>
        <article class="card"><h3>Habitat & role</h3><p>Where it spawns, how it behaves, combat role.</p></article>
        <article class="card"><h3>Abilities</h3><p>Unique skills and combat mechanics.</p></article>
        <article class="card"><h3>Loot examples</h3><p>Items and resources dropped on defeat.</p></article>
        <article class="card"><h3>Color palette</h3><p>Visual design system for the creature family.</p></article>
        <article class="card"><h3>Data pipeline</h3><p>How the same record feeds server, client, database, and wiki.</p></article>
      </div>
    </div>
  </section>
  <section class="section" aria-label="Gallery link">
    <div class="section-inner">
      <div class="actions" style="justify-content: center">
        <a class="button button-primary" href="/gallery/">Browse creature gallery</a>
      </div>
    </div>
  </section>
</StudioLayout>
<style>
  .codex-hero {
    background: radial-gradient(circle at 28% 22%, rgba(192,132,252,0.35), transparent 24rem), radial-gradient(circle at 72% 18%, rgba(244,63,94,0.2), transparent 22rem), linear-gradient(145deg, #1a0a1e 0%, #2d1248 35%, #0f172a 100%);
    color: #f8fafc;
    min-height: min(520px, 60svh);
    display: grid;
    align-items: center;
    padding: clamp(3rem, 9vw, 6rem) var(--space-page);
  }
  .codex-hero-inner { width: min(100%, 72rem); margin: 0 auto; }
  .codex-hero .eyebrow { color: #c084fc; }
  .codex-hero h1 { color: #fff7ed; text-shadow: 0 0 2rem rgba(192,132,252,0.3); }
  .codex-lead { max-width: 42rem; margin: clamp(1.25rem, 3vw, 2rem) 0 0; font-size: clamp(1.15rem, 2.5vw, 1.6rem); line-height: 1.3; color: #e9d5ff; }
</style>
