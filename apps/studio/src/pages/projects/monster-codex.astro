---
import { studioName } from "@zoggy/branding";
import StudioLayout from "../../layouts/StudioLayout.astro";

const title = `Monster Codex | ${studioName}`;
const description = `A structured creature-authoring system for the Dark Fantasy MMO connecting lore, combat, art, and game data.`;
---

<StudioLayout title={title} description={description}>
  <section class="section" aria-labelledby="codex-title">
    <div class="page-content text-stack">
      <p class="eyebrow">Active development</p>
      <h1 id="codex-title" class="page-title">Monster Codex & Content Pipeline</h1>
      <p class="page-intro">A structured creature-authoring system that connects monster identity, visual direction, lore, ecology, combat statistics, abilities, AI, spawning, loot, quests, audio, database records, and in-game presentation into one pipeline.</p>
    </div>
  </section>

  <section class="section" aria-label="Codex overview">
    <div class="section-inner wide-grid">
      <article class="card text-stack">
        <h2>The scope</h2>
        <p>Hundreds of creatures spanning serious dark fantasy monsters, trick monsters, clockwork constructs, aberrations, bosses, mini-bosses, and unique individual records. Each creature carries structured data connecting every aspect of its existence in the game world.</p>
      </article>
      <article class="card text-stack">
        <h2>What the pipeline connects</h2>
        <ul class="note-list">
          <li>Visual direction and creature artwork</li>
          <li>Public lore and in-world ecology</li>
          <li>Combat statistics and abilities</li>
          <li>AI behavior and spawning rules</li>
          <li>Loot tables and quest integration</li>
          <li>Database records and in-game presentation</li>
        </ul>
      </article>
    </div>
  </section>

  <section class="section" aria-label="Case study">
    <div class="section-inner">
      <div class="callout text-stack">
        <h2>Case study: Chonkroach</h2>
        <p>Chonkroach is a single creature that demonstrates how the Codex works end to end:</p>
      </div>
      <div class="wide-grid" style="margin-top: 1rem">
        <article class="card">
          <h3>Creature artwork</h3>
          <p>Visual concept and in-game representation.</p>
        </article>
        <article class="card">
          <h3>Public lore</h3>
          <p>Short in-world description and ecological context.</p>
        </article>
        <article class="card">
          <h3>Dimensions</h3>
          <p>Height, weight, and creature family classification.</p>
        </article>
        <article class="card">
          <h3>Habitat & combat role</h3>
          <p>Where it spawns, how it behaves, and its role in encounters.</p>
        </article>
        <article class="card">
          <h3>Signature abilities</h3>
          <p>Unique skills and combat mechanics.</p>
        </article>
        <article class="card">
          <h3>Loot examples</h3>
          <p>Items and resources dropped on defeat.</p>
        </article>
        <article class="card">
          <h3>Color palette</h3>
          <p>Visual design system for the creature family.</p>
        </article>
        <article class="card">
          <h3>Data pipeline</h3>
          <p>How the same record feeds server, client, database, and future wiki.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section" aria-label="Gallery link">
    <div class="section-inner">
      <div class="actions">
        <a class="button button-primary" href="/gallery/">Browse creature gallery</a>
      </div>
    </div>
  </section>
</StudioLayout>

<style>
  .studio-theme .card h3 {
    margin-bottom: 0.5rem;
  }
</style>
