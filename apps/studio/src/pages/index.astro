---
import { studioName, gameName } from "@zoggy/branding";
import StudioLayout from "../layouts/StudioLayout.astro";

const title = `${studioName} | Games, Tools, and Strange Worlds Built One System at a Time`;
const description = `${studioName} is a solo-led creative and technology studio developing games, tools, creature-filled worlds, and technical experiments.`;
---
<StudioLayout title={title} description={description}>
  <section class="hero" aria-labelledby="studio-title">
    <div class="hero-visual" aria-hidden="true">
      <div class="hero-shape shape-a"></div>
      <div class="hero-shape shape-b"></div>
      <div class="hero-shape shape-c"></div>
    </div>
    <div class="hero-inner">
      <div>
        <p class="eyebrow">Solo-led game and technology studio</p>
        <h1 id="studio-title">Games, tools, and strange worlds built one system at a time.</h1>
        <p class="lead">Zoggy Studios develops original games, practical development tools, creature-filled worlds, and technical experiments. Current work centers on a dark fantasy MMORPG, its supporting server technology, world-building tools, and content pipeline.</p>
        <div class="actions" aria-label="Primary links">
          <a class="button button-primary" href="/projects/">Explore projects</a>
          <a class="button button-secondary" href="/now/">What I am working on now</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="current-work-title">
    <div class="section-inner">
      <div class="section-heading">
        <h2 id="current-work-title">Current work</h2>
        <p>What the studio is actively building right now.</p>
      </div>
      <div class="wide-grid">
        <article class="card project-card">
          <span class="status-pill">Active development</span>
          <h3>{gameName}</h3>
          <p>An old-school-inspired dark fantasy MMORPG with a Godot client, authoritative Go server, persistent world, and deep creature ecology.</p>
          <a class="button button-secondary" href="/projects/dark-fantasy-mmo/">Project details</a>
        </article>
        <article class="card project-card">
          <span class="status-pill">Internal tool</span>
          <h3>Development Supervisor</h3>
          <p>A Go-based control suite for building, launching, monitoring, and troubleshooting the MMO server and its supporting services.</p>
          <a class="button button-secondary" href="/projects/development-supervisor/">Project details</a>
        </article>
        <article class="card project-card">
          <span class="status-pill">In development</span>
          <h3>Groundmaker & World Pipeline</h3>
          <p>Terrain and zone-authoring tools that connect the Godot world to authoritative server data for a seamless multiplayer environment.</p>
          <a class="button button-secondary" href="/projects/groundmaker/">Project details</a>
        </article>
        <article class="card project-card">
          <span class="status-pill">Active development</span>
          <h3>Monster Codex</h3>
          <p>A structured creature-authoring system turning monster ideas, art, lore, stats, abilities, and loot into game-ready content.</p>
          <a class="button button-secondary" href="/projects/monster-codex/">Project details</a>
        </article>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="creature-title">
    <div class="section-inner">
      <div class="section-heading">
        <h2 id="creature-title">From the creature archive</h2>
        <p>Selected monsters from the Codex. Each creature connects lore, combat, loot, and in-game behavior through a structured data pipeline.</p>
      </div>
      <div class="actions">
        <a class="button button-secondary" href="/gallery/">View the creature gallery</a>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="tech-title">
    <div class="section-inner">
      <div class="section-heading">
        <h2 id="tech-title">Technology from the workshop</h2>
        <p>Practical engineering writing about what the studio is building and how it works.</p>
      </div>
      <div class="wide-grid">
        <article class="card">
          <h3>Why a Development Supervisor exists</h3>
          <p>Launching several dev services without enough visibility into build failures, startup ordering, and connection problems led to a practical tool.</p>
        </article>
        <article class="card">
          <h3>Keeping Godot and Go on the Same Grid</h3>
          <p>Translating between server units, Godot units, logical tiles, elevation layers, entity origins, and area-of-interest cells.</p>
        </article>
      </div>
      <div class="actions" style="margin-top: 1.5rem">
        <a class="button button-secondary" href="/technology/">More technology notes</a>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="experimental-title">
    <div class="section-inner">
      <div class="section-heading">
        <h2 id="experimental-title">Experimental shelf</h2>
        <p>Older concepts and prototype ideas that inform current work.</p>
      </div>
      <div class="wide-grid">
        <article class="card">
          <span class="status-pill">Prototype</span>
          <h3>Empire of the Hill</h3>
          <p>An ant-colony RTS and survival experiment exploring colony simulation, pheromone systems, and isometric strategy gameplay.</p>
          <a class="button button-secondary" href="/projects/empire-of-the-hill/">Read more</a>
        </article>
        <article class="card">
          <span class="status-pill">Exploring</span>
          <h3>Experimental Lab</h3>
          <p>Smaller game concepts, characters, art experiments, and prototype ideas collected in one place.</p>
          <a class="button button-secondary" href="/projects/experimental-lab/">Browse experiments</a>
        </article>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="start-title">
    <div class="section-inner">
      <div class="callout text-stack" style="text-align: center">
        <span class="status-pill">Right now</span>
        <h2 id="start-title">Start honest. Expand when the work earns it.</h2>
        <p style="max-width: 38rem; margin: 0 auto">This site avoids fake portfolios, fake team size, fake press, and fake launch promises. It shows what exists, what is being explored, and what is intentionally waiting.</p>
        <div class="actions" style="justify-content: center">
          <a class="button button-primary" href="/about/">About the studio</a>
          <a class="button button-secondary" href="/contact/">Get in touch</a>
        </div>
      </div>
    </div>
  </section>
</StudioLayout>

<style>
  .hero { position: relative; overflow: hidden; }
  .hero-visual { position: absolute; inset: 0; pointer-events: none; z-index: 0; overflow: hidden; }
  .hero-shape { position: absolute; border-radius: 50%; opacity: 0.5; }
  .shape-a { width: 38rem; height: 38rem; background: radial-gradient(circle, rgba(56,189,248,0.2), transparent 70%); top: -12rem; right: -8rem; }
  .shape-b { width: 28rem; height: 28rem; background: radial-gradient(circle, rgba(250,204,21,0.15), transparent 70%); bottom: -6rem; left: -6rem; }
  .shape-c { width: 18rem; height: 18rem; background: radial-gradient(circle, rgba(192,132,252,0.12), transparent 70%); top: 40%; left: 55%; }
  .hero-inner { position: relative; z-index: 1; }
</style>
