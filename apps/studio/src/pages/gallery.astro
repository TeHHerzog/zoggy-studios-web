---
import { studioName } from "@zoggy/branding";
import StudioLayout from "../layouts/StudioLayout.astro";

const title = `Gallery | ${studioName}`;
const description = `Creature artwork, monster collections, and visual development from ${studioName}.`;

const collections = [
  {
    name: "Dark Fantasy Creatures",
    desc: "The core monster population of the MMO world.",
    color: "#c084fc",
    svg: "M24 8L40 8L48 24L40 40L24 48L8 40L8 24Z"
  },
  {
    name: "Trick &amp; Toon Monsters",
    desc: "Unusual creatures that break the dark fantasy tone.",
    color: "#facc15",
    svg: "M8 16C8 16 24 8 40 16C56 24 48 40 48 40C48 40 32 48 16 40C8 36 8 16 8 16Z"
  },
  {
    name: "Clockwork Constructs",
    desc: "Mechanical creatures built from gears and magic.",
    color: "#38bdf8",
    svg: "M16 8L48 8L56 24L48 40L16 40L8 24Z"
  },
  {
    name: "Frost Creatures",
    desc: "Beasts adapted to frozen wastes and arctic zones.",
    color: "#67e8f9",
    svg: "M32 8L48 32L32 56L16 32Z"
  },
  {
    name: "Moon-Touched Beasts",
    desc: "Creatures altered by lunar influence.",
    color: "#a78bfa",
    svg: "M32 8C40 8 48 16 48 24C48 36 40 48 32 52C24 48 16 36 16 24C16 16 24 8 32 8Z"
  },
  {
    name: "Bosses &amp; Mini-Bosses",
    desc: "Named encounters with unique mechanics and loot.",
    color: "#fb7185",
    svg: "M16 8L48 8L56 24L48 40L16 40L8 24Z"
  },
  {
    name: "Pixel &amp; Character Experiments",
    desc: "Sprite work and pixel art across Zoggy projects.",
    color: "#34d399",
    svg: "M16 12L32 8L48 12L48 36L32 56L16 36Z"
  }
];
---
<StudioLayout title={title} description={description}>
  <section class="gallery-hero" aria-labelledby="gallery-title">
    <div class="gallery-hero-inner">
      <p class="eyebrow">Creature gallery</p>
      <h1 id="gallery-title">From the Monster Codex.</h1>
      <p class="gallery-lead">Selected creatures from the Dark Fantasy MMO content pipeline. Each entry connects visual design with lore, combat data, and in-game behavior through the structured authoring system.</p>
    </div>
  </section>
  <section class="section" aria-label="Gallery collections">
    <div class="section-inner">
      <div class="section-heading">
        <h2>Collections</h2>
        <p>Browse creatures by category. Each collection shows curated entries.</p>
      </div>
      <div class="gallery-grid">
        {collections.map((col) => (
          <div class="gallery-card">
            <div class="gallery-preview" style={`--accent: ${col.color}`}>
              <svg class="creature-icon" viewBox="0 0 64 64" fill="none" stroke={col.color} stroke-width="2" stroke-linejoin="round" aria-hidden="true">
                <path d={col.svg} />
                <circle cx="24" cy="24" r="3" fill={col.color} opacity="0.6" />
                <circle cx="40" cy="24" r="3" fill={col.color} opacity="0.6" />
              </svg>
            </div>
            <h3 set:html={col.name}></h3>
            <p>{col.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <section class="section" aria-label="Note">
    <div class="section-inner">
      <div class="callout text-stack" style="text-align: center">
        <h2>Artwork being prepared</h2>
        <p>The gallery will feature curated creature artwork, screenshots, and development images as material is cleared. Check <a href="/updates/">the studio log</a> for new additions.</p>
      </div>
    </div>
  </section>
</StudioLayout>

<style>
  .gallery-hero { background: radial-gradient(circle at 22% 18%, rgba(192,132,252,0.3), transparent 22rem), radial-gradient(circle at 78% 78%, rgba(52,211,153,0.15), transparent 20rem), linear-gradient(155deg, #0f172a 0%, #1e1b4b 52%, #0f172a 100%); color: #f8fafc; min-height: min(480px, 56svh); display: grid; align-items: center; padding: clamp(3rem, 9vw, 5rem) var(--space-page); }
  .gallery-hero-inner { width: min(100%, 72rem); margin: 0 auto; }
  .gallery-hero .eyebrow { color: #c084fc; }
  .gallery-hero h1 { color: #fff7ed; }
  .gallery-lead { max-width: 42rem; margin: clamp(1.25rem, 3vw, 2rem) 0 0; font-size: clamp(1.1rem, 2.5vw, 1.5rem); color: #e9d5ff; }
  .gallery-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr)); gap: 1.25rem; }
  .gallery-card { border-radius: var(--radius-card); overflow: hidden; border: 1px solid rgba(17,24,39,0.12); background: rgba(255,255,255,0.68); }
  .gallery-card h3 { margin: 1rem 1.25rem 0.35rem; font-family: var(--font-display); font-weight: 900; }
  .gallery-card p { margin: 0 1.25rem 1.25rem; font-size: 0.9rem; color: #374151; }
  .gallery-preview { width: 100%; aspect-ratio: 16/9; background: linear-gradient(135deg, #1e1b4b 0%, #0f172a 100%); display: flex; align-items: center; justify-content: center; position: relative; }
  .gallery-preview::after { content: ""; position: absolute; inset: 0; background: radial-gradient(circle at 32% 28%, color-mix(in srgb, var(--accent) 25%, transparent), transparent 16rem); }
  .creature-icon { width: 64px; height: 64px; position: relative; z-index: 1; opacity: 0.85; }
</style>
