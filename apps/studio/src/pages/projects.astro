---
import { studioName } from "@zoggy/branding";
import StudioLayout from "../layouts/StudioLayout.astro";

const title = `Projects | ${studioName}`;
const description = `Active projects and experiments from ${studioName}.`;
---

<StudioLayout title={title} description={description}>
  <section class="section" aria-labelledby="projects-title">
    <div class="page-content text-stack">
      <p class="eyebrow">Project shelf</p>
      <h1 id="projects-title" class="page-title">What the studio is building.</h1>
      <p class="page-intro">Each project here represents real work in progress, from game systems and server infrastructure to creature design and world-building tools.</p>
    </div>
  </section>

  <section class="section" aria-label="Active projects">
    <div class="section-inner">
      <div class="wide-grid">
        <article class="card project-card">
          <span class="status-pill">Active development</span>
          <h2>Dark Fantasy MMO</h2>
          <p>An old-school-inspired dark fantasy MMORPG featuring a Godot 4.7 client, authoritative Go game server, persistent world, deep class identity, creature ecology, and server-authoritative gameplay.</p>
          <a class="button button-secondary" href="/projects/dark-fantasy-mmo/">View project</a>
        </article>
        <article class="card project-card">
          <span class="status-pill">Internal tool</span>
          <h2>Development Supervisor & Control Suite</h2>
          <p>A Go-based tool for building, launching, monitoring, and troubleshooting the game server and its supporting services with live process output and health tracking.</p>
          <a class="button button-secondary" href="/projects/development-supervisor/">View project</a>
        </article>
        <article class="card project-card">
          <span class="status-pill">In development</span>
          <h2>Groundmaker & World Pipeline</h2>
          <p>Terrain and zone-authoring tools that create world data readable by both the Godot client and the authoritative Go server for persistent multiplayer zones.</p>
          <a class="button button-secondary" href="/projects/groundmaker/">View project</a>
        </article>
        <article class="card project-card">
          <span class="status-pill">Active development</span>
          <h2>Monster Codex & Content Pipeline</h2>
          <p>A structured creature-authoring system connecting monster identity, visual direction, lore, ecology, combat stats, abilities, AI, spawning, loot, quests, and database records.</p>
          <a class="button button-secondary" href="/projects/monster-codex/">View project</a>
        </article>
        <article class="card project-card">
          <span class="status-pill">Prototype</span>
          <h2>Empire of the Hill</h2>
          <p>A 2D/2.5D ant-colony RTS and survival experiment inspired by colony simulation and classic strategy games.</p>
          <a class="button button-secondary" href="/projects/empire-of-the-hill/">View project</a>
        </article>
        <article class="card project-card">
          <span class="status-pill">Exploring</span>
          <h2>Experimental Lab</h2>
          <p>A single home for smaller game concepts, character ideas, art experiments, and prototype concepts.</p>
          <a class="button button-secondary" href="/projects/experimental-lab/">Browse experiments</a>
        </article>
      </div>
    </div>
  </section>
</StudioLayout>
