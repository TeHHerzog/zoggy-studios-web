---
import "@zoggy/ui/styles.css";
import { studioName, studioShortName } from "@zoggy/branding";

const {
  title,
  description,
  image = "/social-card.svg"
} = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? "https://games.herzogit.com");
const socialImageUrl = new URL(image, canonicalUrl);
const navItems = [
  { href: "/", label: "Home" },
  { href: "/projects/", label: "Projects" },
  { href: "/gallery/", label: "Gallery" },
  { href: "/technology/", label: "Technology" },
  { href: "/work/", label: "Work" },
  { href: "/now/", label: "Now" },
  { href: "/about/", label: "About" },
  { href: "/updates/", label: "Log" },
  { href: "/contact/", label: "Contact" }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fff7ed" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;700;800;900&display=swap" rel="stylesheet" />
    <link rel="alternate icon" href="/favicon.ico" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={studioName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <title>{title}</title>
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme') || 
          (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        if (theme === 'dark') {
          document.documentElement.classList.add('dark-theme');
        } else {
          document.documentElement.classList.remove('dark-theme');
        }
      })();
    </script>
  </head>
  <body class="studio-theme">
    <a class="skip-link" href="#main-content">Skip to content</a>
    <div class="page-shell">
      <header class="site-header" aria-label={`${studioName} site header`}>
        <a class="brand-link" href="/" aria-label={`${studioName} home`}>
          <img class="brand-mark" src="/brand-mark.svg" alt="" width="38" height="38" loading="eager" />
          <span>{studioName}</span>
        </a>
        <nav class="site-nav" aria-label="Primary navigation">
          {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
          <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme" title="Toggle color theme">
            <svg class="sun-icon" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="4"></circle>
              <path d="M12 2v2"></path>
              <path d="M12 20v2"></path>
              <path d="M4.93 4.93l1.41 1.41"></path>
              <path d="M17.66 17.66l1.41 1.41"></path>
              <path d="M2 12h2"></path>
              <path d="M20 12h2"></path>
              <path d="M6.34 17.66l-1.41 1.41"></path>
              <path d="M19.07 4.93l-1.41 1.41"></path>
            </svg>
            <svg class="moon-icon" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
            </svg>
          </button>
        </nav>
      </header>
      <main id="main-content" class="main-content">
        <slot />
      </main>
      <footer class="site-footer">
        <span>{studioName}</span>
        <span>{studioShortName} is a solo-led studio for games, apps, stories, and strange new worlds.</span>
        <span class="footer-links">
          <a href="/privacy/">Privacy</a>
          <a href="/terms/">Terms</a>
        </span>
      </footer>
    </div>
    <script>
      const toggleBtn = document.getElementById('theme-toggle');
      if (toggleBtn) {
        toggleBtn.addEventListener('click', () => {
          const isDark = document.documentElement.classList.contains('dark-theme');
          if (isDark) {
            document.documentElement.classList.remove('dark-theme');
            localStorage.setItem('theme', 'light');
          } else {
            document.documentElement.classList.add('dark-theme');
            localStorage.setItem('theme', 'dark');
          }
        });
      }
    </script>
  </body>
</html>

<style>
  .studio-theme {
    background: var(--bg-gradient);
    color: var(--text-color);
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  .studio-theme .site-header,
  .studio-theme .site-footer {
    border-color: var(--header-border);
    transition: border-color 0.3s ease;
  }

  .studio-theme .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    border-bottom: 1px solid var(--header-border);
    background: var(--header-bg);
    backdrop-filter: blur(18px);
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  .studio-theme .site-footer {
    border-top: 1px solid var(--header-border);
  }

  .studio-theme .brand-mark {
    display: block;
  }

  .studio-theme .site-nav a {
    color: var(--text-secondary);
  }

  .studio-theme .site-nav a:hover,
  .studio-theme .site-nav a:focus-visible {
    background: rgba(17, 24, 39, 0.08);
    color: var(--text-color);
  }

  :global(.dark-theme) .studio-theme .site-nav a:hover,
  :global(.dark-theme) .studio-theme .site-nav a:focus-visible {
    background: rgba(255, 255, 255, 0.08);
  }

  .footer-links {
    display: inline-flex;
    gap: 0.8rem;
  }

  .footer-links a {
    font-weight: 800;
  }

  .header-note,
  .studio-theme .supporting,
  .studio-theme .site-footer {
    color: var(--text-secondary);
  }

  .studio-theme .eyebrow {
    color: var(--accent-color);
  }

  .studio-theme .lead {
    color: var(--text-secondary);
  }

  .studio-theme .button-primary {
    border-color: var(--text-color);
    background: var(--text-color);
    color: var(--card-bg);
  }

  .studio-theme .button-secondary {
    background: var(--card-bg);
    color: var(--text-color);
    border-color: var(--card-border);
  }

  .studio-theme .card {
    border: 1px solid var(--card-border);
    background: var(--card-bg);
    box-shadow: var(--card-shadow);
    transition: border-color 0.25s ease, background-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .studio-theme .card:hover {
    border-color: var(--card-hover-border);
    box-shadow: var(--card-hover-shadow);
    transform: var(--card-hover-transform);
  }

  .studio-theme .hero-panel,
  .studio-theme .callout,
  .studio-theme .timeline li {
    border: 1px solid var(--card-border);
    background: var(--card-bg);
    box-shadow: var(--card-shadow);
    transition: border-color 0.25s ease, background-color 0.25s ease, box-shadow 0.25s ease;
  }

  .studio-theme .status-pill {
    color: var(--badge-color);
    background: var(--badge-bg);
    border-color: transparent;
  }
</style>
